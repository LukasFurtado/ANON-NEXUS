{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NEXUS ANON",
  "version": "1.7.5",
  "identifier": "br.gov.local.nexus-anon",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "NEXUS ANON",
        "width": 1320,
        "height": 860,
        "minWidth": 1040,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
