          "DataAtualizacaoConta",
          "bitPepCitado",
          "bitPessoaObrigadaCitado",
          "intServidorCitado"
        ]
      },
      "rif_ocorrencias": {
        "purpose": "Tabela de ocorrencias, classificacoes e fundamentos operacionais vinculados ao Indexador.",
        "required_headers": ["Indexador", "idOcorrencia", "Ocorrencia"],
        "anonymize_columns": [],
        "preserve_columns": ["Indexador", "idOcorrencia", "Ocorrencia"],
        "rule": "Nao anonimizar codigos, tipos de ocorrencia ou descricoes tecnico-operacionais, salvo dado pessoal acidental."
      },
      "rif_comunicacoes": {
        "purpose": "Tabela de comunicacoes COAF com dados de comunicante, datas, valores e narrativa operacional.",
        "required_headers": [
          "Indexador",
          "idComunicacao",
          "NumeroOcorrenciaBC",
          "Data_do_Recebimento",
          "Data_da_operacao",
          "cpfCnpjComunicante",
          "nomeComunicante",
          "informacoesAdicionais",
          "CodigoSegmento"
        ],
        "narrative_columns": ["informacoesAdicionais"],
        "anonymize_inside_narrative": [
          "pessoa_fisica",
          "empresa_privada_sensivel",
          "cpf_cnpj_contraparte",
          "conta",
          "agencia",
          "pix",
          "endereco",
          "telefone",
          "email"
        ],
        "preserve_columns": [
          "Indexador",
          "idComunicacao",
          "NumeroOcorrenciaBC",
          "Data_do_Recebimento",
          "Data_da_operacao",
          "DataFimFato",
