    },
    "subtypes": {
      "rif_envolvidos": {
        "purpose": "Tabela relacional de pessoas e entidades vinculadas ao RIF.",
        "required_headers": [
          "Indexador",
          "cpfCnpjEnvolvido",
          "nomeEnvolvido",
          "tipoEnvolvido",
          "agenciaEnvolvido",
          "contaEnvolvido"
